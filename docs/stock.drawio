        <mxCell id="IZIkf1baD0dLr57dKXiw-12" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=13;" value="&lt;b&gt;Tác nhân&lt;/b&gt;:&lt;div&gt;- Tôi (user): dùng thực hiện các thao tác trong hệ thống như nhập gd, sửa, import, xem phân tích&lt;/div&gt;" vertex="1">
