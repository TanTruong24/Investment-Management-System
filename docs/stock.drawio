        <mxCell id="3tNoCV5g4BuNFWaW4ihS-260" edge="1" parent="3tNoCV5g4BuNFWaW4ihS-263" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;curved=0;rounded=0;" target="3tNoCV5g4BuNFWaW4ihS-158" value="OK">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1334.5" y="1490" as="sourcePoint" />
            <mxPoint x="1070" y="1490" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="3tNoCV5g4BuNFWaW4ihS-261" edge="1" parent="3tNoCV5g4BuNFWaW4ihS-263" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;curved=0;rounded=0;" value="return success (transaction_id, data)">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="449.5" y="1520" as="sourcePoint" />
            <mxPoint x="210" y="1520" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="3tNoCV5g4BuNFWaW4ihS-262" edge="1" parent="3tNoCV5g4BuNFWaW4ihS-263" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;endSize=8;curved=0;rounded=0;" value="show success, refresh data/list">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="210" y="1594" as="sourcePoint" />
            <mxPoint x="10" y="1594" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="3tNoCV5g4BuNFWaW4ihS-266" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=13;" value="&lt;ol&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Chuẩn hóa tiêu chí deduplicate cho đúng với schema&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Nếu là import từ broker: deduplicate theo (account_id, source, external_order_no). Có thể bổ sung trade_date nếu cần giảm trùng giả&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Nếu là manual create: xác định rõ có deduplicate hay không. Nếu có thì dùng business key (trade_date, instrument_id, type, order_quantity, order_price) hoặc hash&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;ol start=&quot;2&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Bổ sung nhánh kiểm tra thiếu tiền khi BUY&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Tính total_cost = matched_quantity * matched_price + fee_amount + tax_amount&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Nếu available_cash hoặc buying_power &amp;lt; total_cost thì trả lỗi và rollback transaction&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;ol start=&quot;3&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Bổ sung nhánh kiểm tra bán quá số lượng khi SELL&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Lấy current_quantity từ positions&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Nếu sell_quantity &amp;gt; current_quantity thì trả lỗi và rollback&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Xác định rõ có cho phép short sell hay không. Nếu không thì phải chặn&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;ol start=&quot;4&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Bổ sung nhánh kiểm tra thiếu tiền khi WITHDRAW&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Nếu withdraw_amount &amp;gt; available_cash thì trả lỗi và rollback&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Nếu có khái niệm pending_cash thì xác định rule: chỉ được rút từ available_cash hay cả pending_cash&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;ol start=&quot;5&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Làm rõ matched_quantity và matched_price khi create transaction&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Nếu create transaction đồng nghĩa đã khớp lệnh: set matched_quantity = order_quantity, matched_price = order_price&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Nếu có trạng thái khớp lệnh từng phần: cần rule cập nhật matched_* theo từng lần khớp hoặc theo file import&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;ol start=&quot;6&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Bổ sung xử lý instrument_id nullable theo type&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Với DEPOSIT/WITHDRAW: instrument_id phải null, không gọi Position manage&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Với BUY/SELL: instrument_id bắt buộc có, nếu null thì trả lỗi&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;ol start=&quot;7&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Bổ sung phần rollback khi lỗi ở giữa luồng&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Nếu insert transaction record xong nhưng update position/balance lỗi: rollback toàn bộ&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Nên ghi rõ BEGIN, COMMIT, ROLLBACK trong sơ đồ cho nhánh lỗi&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;ol start=&quot;8&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Bổ sung kiểm tra trạng thái position khi SELL&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Nếu position không tồn tại thì trả lỗi&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Nếu position tồn tại nhưng quantity = 0 thì trả lỗi (hoặc xử lý theo rule của bạn)&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;ol start=&quot;9&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Làm rõ các field balance được cập nhật trong từng loại giao dịch&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;BUY: available_cash giảm, buying_power giảm (hoặc chỉ available_cash nếu không dùng buying_power)&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;SELL: available_cash tăng, buying_power tăng&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;DEPOSIT: total_cash tăng, available_cash tăng, buying_power tăng (tùy định nghĩa)&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;WITHDRAW: total_cash giảm, available_cash giảm, buying_power giảm&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;ol start=&quot;10&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Bổ sung quy ước làm tròn và đơn vị tiền tệ&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Xác định rounding cho price, fee, tax, pnl theo currency/unit&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Tránh sai số tích lũy khi tính avg_cost và realized_pnl&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;ol start=&quot;11&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Bổ sung điều kiện đồng thời khi update (concurrency)&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Nếu có khả năng tạo nhiều transaction cùng lúc: cần locking hoặc optimistic version để tránh race condition làm sai quantity/cash&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Ví dụ: update positions/balances theo dạng atomic update (SET value = value + delta) hoặc có version column&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;ol start=&quot;12&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Bổ sung output trả về sau khi tạo thành công&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Trả transaction_id và dữ liệu snapshot cần cho UI refresh (transaction vừa tạo, position mới, balance mới)&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;font&gt;Hoặc xác định rõ UI sẽ gọi lại API list để refresh dữ liệu&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="1200" width="1360" x="1720" y="1460" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
