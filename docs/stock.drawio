        <mxCell id="IZIkf1baD0dLr57dKXiw-204" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Khi xác định use case:&amp;nbsp;&lt;b&gt;Các hành động chủ yếu làm cho nghiệp vụ đó hoạt động là gì?&lt;/b&gt;" vertex="1">
